{
  "expo": {
    "name": "Phraseman",
    "slug": "phraseman",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "phraseman",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "app.phraseman",
      "versionCode": 16,
      "adaptiveIcon": {
        "backgroundColor": "#06141B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "app.phraseman",
      "buildNumber": "5",
      "supportsTablet": false,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Phraseman uses speech recognition to check your English pronunciation during lessons. Your voice is processed on-device and not stored.",
        "NSMicrophoneUsageDescription": "Phraseman uses the microphone to listen to your spoken English answers during pronunciation practice in lessons."
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#06141B",
          "dark": {
            "backgroundColor": "#06141B"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-foreground.png",
          "color": "#06141B"
        }
      ],
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6235200-f736-4f96-ab81-09354d945ba8"
      }
    }
  }
}
